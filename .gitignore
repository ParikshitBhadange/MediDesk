# ============================================================
# MediDesk — root .gitignore
# Covers backend (Node/Express/Prisma) + frontend (Vite/React) + Docker/CI
# ============================================================

# ---- Secrets & environment files (NEVER commit real credentials) ----
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.crt
*.cert
*.p12
*credentials*.json
*secret*.json

# ---- Dependencies ----
node_modules/
**/node_modules/
.npm/
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---- Build output ----
dist/
build/
**/dist/
**/build/
.vite/
.next/
out/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ---- Prisma ----
backend/prisma/*.db
backend/prisma/migrations/dev/
*.sqlite
*.sqlite3

# ---- Testing / coverage ----
coverage/
.nyc_output/

# ---- OS files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ---- Docker ----
docker-compose.override.yml
*.pid

# ---- Deployment / platform-specific ----
.vercel/
.render/

# ---- Misc ----
*.tmp
*.temp
.cache/
.eslintcache